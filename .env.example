# ─── Go High Level ────────────────────────────────────────────────────────────
# Ajustes > Integraciones privadas > crea una con scope: contacts.write, opportunities.write, notes.write
GHL_API_KEY=your_private_integration_api_key

# Settings > Business Info > Location ID (string tipo: abc123XYZ)
GHL_LOCATION_ID=your_location_id

# Pipelines > elige tu pipeline > copia el ID de la URL
GHL_PIPELINE_ID=your_pipeline_id

# Dentro del pipeline, la etapa "Nuevo Lead" o similar > copia el ID
GHL_STAGE_NUEVO_LEAD=your_stage_id

# ─── Calendario ───────────────────────────────────────────────────────────────
# URL de tu calendario GHL o Cal.com que aparece tras enviar el formulario
NEXT_PUBLIC_CALENDAR_URL=https://link.de.tu.calendario
